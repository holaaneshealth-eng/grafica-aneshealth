{
  "name": "aneshealth-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Backend seguro para la hoja anestesica digital (auth, RBAC, event store, auditoria).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
