# Copia este archivo a .env y ajusta los valores. NUNCA subas .env al repositorio.

NODE_ENV=production
PORT=8080

# Base de datos Postgres. En produccion, la cadena de conexion de Neon (https://neon.tech),
# por ejemplo: postgresql://usuario:password@ep-xxx.eu-central-1.aws.neon.tech/aneshealth?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aneshealth

# OBLIGATORIO en produccion. Genera uno con: openssl rand -hex 48
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio

# Carpeta local para el archivo de credenciales iniciales (opcional; puede ser efimera)
DATA_DIR=./data

# Retencion / autoborrado de pacientes (dias)
RETENTION_DAYS=15

# --- Seed inicial de usuarios (opcional) ---
# Si defines estas variables, se usaran como contrasenas iniciales (sin forzar cambio).
# Si las dejas vacias, se generan contrasenas aleatorias que aparecen en los LOGS del servidor
# y se exige cambiarlas en el primer inicio de sesion.
# ADMIN_PASSWORD=
# CLINICAL_PASSWORD_PREFIX=

# Endurecimiento de login
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15
BCRYPT_ROUNDS=12
SESSION_TTL_SECONDS=43200
